#include <iostream>
using namespace std;

int main() 
{
    int start, end;
    cin >> start >> end;

    int totalOdd;
    totalOdd = (end + 1) / 2 - (start / 2);

    if (totalOdd % 2 == 0) 
    {
        cout << "even" << endl;
    } 
    else 
    {
        cout << "odd" << endl;
    }

    return 0;
}
